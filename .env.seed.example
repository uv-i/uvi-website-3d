# ── Seed Script Variables ─────────────────────────────────────────────────────
# Copy this file to .env.seed and fill in the values.
# Used ONLY by scripts/seed-sanity.js — never by the website itself.
#
# ⚠️  .env.seed contains a secret write token — NEVER commit it.
#     It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

SANITY_PROJECT_ID=
SANITY_DATASET=production

# Create a token at: sanity.io/manage → your project → API → Tokens → Add token
# Choose "Editor" role (allows creating documents)
SANITY_TOKEN=
